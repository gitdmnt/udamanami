# Rust build artifacts, in any crate of the monorepo (app/, workers/, shared/).
**/target/
Cargo.lock
db.sqlite

# Local deployment secrets -- never commit real tokens.
.env
app/deploy/*.env
!app/deploy/*.env.example
# wrangler dev がローカルで読む秘密情報 (AUTH_TOKEN / OPENAI_API_KEY)。
workers/.dev.vars

.wrangler/