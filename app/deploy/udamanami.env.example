# udamanami runtime configuration.
#
# Copy this file to deploy/udamanami.env, fill in real values, then push it to
# Secret Manager as a new version:
#
#   gcloud secrets versions add udamanami-env \
#     --project <PROJECT_ID> --data-file deploy/udamanami.env
#
# Format: KEY=value, one per line. No `export`, no surrounding quotes. Values are
# loaded by entrypoint.sh via `source`, so they must not contain spaces, quotes,
# or other shell metacharacters (Discord and Gemini tokens never do). Lines that
# start with # are ignored.
#
# DATABASE_PATH is intentionally omitted: the image defaults it to /data/db.sqlite,
# which is backed by the instance's persistent boot disk.

# --- Required ---
DISCORD_TOKEN=your-discord-bot-token
DISCORD_GUILD_ID=000000000000000000

# --- LLM (OpenAI-compatible) ---
# API key for the LLM endpoint (OpenAI by default).
LLM_API_KEY=your-openai-api-key
# Models offered by /model and /auto (comma-separated).
LLM_MODELS=gpt-5.4-mini,gpt-5.4-nano,gpt-5.6-luna
# Default model (optional; defaults to the first entry of LLM_MODELS).
# LLM_MODEL=gpt-5.4-nano
# OpenAI-compatible base URL (optional; default below). Point it at OpenRouter,
# a Gemini OpenAI-compat endpoint, or a LiteLLM proxy to use other providers.
# LLM_BASE_URL=https://api.openai.com/v1
LLM_EFFORT=none

# --- Channels ---
# Default relay target for users who have not picked one with /channel.
DEFAULT_CHANNEL_ID=000000000000000000
# Debug channel used for AI chatter and the startup greeting.
DEBUG_ROOM_ID=000000000000000000

# --- Jail roles (optional) ---
JAIL_MARK_ROLE_ID=000000000000000000
JAIL_MAIN_ROLE_ID=000000000000000000

# --- Optional ---
# Comma-separated command names to disable.
# DISABLED_COMMANDS=
